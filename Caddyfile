# ============================================================
# Caddy 反向代理配置
# 支持两种模式:
#   1. 有域名: 自动 HTTPS (Let's Encrypt)
#   2. 纯 IP:  HTTP 模式 (取消下方 :80 注释)
# ============================================================

# ── 有域名时使用（替换为你的真实域名）──
{$SITE_ADDRESS:localhost} {
    reverse_proxy core:{$PORT:3001}
}
