# ============================================================
# Caddy 反向代理配置
#
# Cloudflare 代理模式 (推荐):
#   SITE_ADDRESS=:80  → Caddy 仅做 HTTP 反代, SSL 由 CF 终结
#
# 自签 HTTPS 模式 (无 CF):
#   SITE_ADDRESS=yourdomain.com → Caddy 自动 Let's Encrypt
# ============================================================

{$SITE_ADDRESS::80} {
    reverse_proxy core:{$PORT:3001}
}
