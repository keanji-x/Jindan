# ============================================================
# Caddy 反向代理配置 (Cloudflare Full SSL)
#
# Caddy 在 443 上用自签证书提供 HTTPS,
# Cloudflare 以 "Full" 模式连接到此端口。
# ============================================================

:443 {
    tls internal
    reverse_proxy core:3001
}

:80 {
    redir https://{host}{uri} permanent
}
