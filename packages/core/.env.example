# ============================================================
# 金丹 Core Server 环境配置
# 本地开发 + Docker 部署共用此文件
# ============================================================

# ── 认证 ──────────────────────────────────────────────────
# JWT 签名密钥 (必须设置! 生成方式: openssl rand -hex 32)
JWT_SECRET="jindan-dev-secret-do-not-use-in-production"

# 邀请码 (留空=公开注册, 设值=注册时校验)
INVITE_CODE=""

# CORS 允许的源 (逗号分隔, 留空=仅 localhost)
# 部署时设为: https://yourdomain.com
CORS_ORIGINS=""

# ── 夺舍保护 ──────────────────────────────────────────────
# 每 IP 夺舍频率限制窗口 (毫秒, 默认 10 分钟)
ATTACH_RATE_LIMIT_WINDOW_MS=600000
# 窗口内最大夺舍次数 (默认 5)
ATTACH_RATE_LIMIT_MAX=5
# 被夺舍实体不活跃超时 (毫秒, 默认 30 分钟, 超时后自动释放控制权)
ATTACH_INACTIVITY_TIMEOUT_MS=1800000

# ── 服务 ──────────────────────────────────────────────────
# API 服务端口
PORT=3001

# ── 数据库 ────────────────────────────────────────────────
# 留空=内存模式 (开发用, 重启丢数据)
# 填写=PostgreSQL (例: postgresql://jindan:pass@localhost:5432/jindan)
DATABASE_URL=""

# ── Docker 部署专用 (本地开发可忽略) ──────────────────────
# 域名 (Caddy 自动申请 HTTPS; 纯 IP 用 http://1.2.3.4)
SITE_ADDRESS="localhost"

# PostgreSQL 密码 (docker-compose 创建 PG 容器时使用)
PG_PASSWORD="jindan_secret"
