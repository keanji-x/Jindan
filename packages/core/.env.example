# Core Backend Environment Configuration
# These are loaded specifically by the @jindan/core API Server

# Database Configuration
# Optional: PostgreSQL Connection String (uses in-memory storage if empty)
# Typically auto-injected when using Docker Compose
DATABASE_URL=""

# Bot Chat Feature
# Secret code required for signing up (Leave empty to allow public registrations)
INVITE_CODE=""

# JWT Signature Key (MUST change in production!)
JWT_SECRET="jindan-secret-key-change-in-production"
