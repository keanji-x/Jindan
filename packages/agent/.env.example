# Agent 环境配置
# 复制此文件为 .env 并填入实际值

# ── API 服务器 ──────────────────────────
JINDAN_HOST=http://localhost:3001

# ── Agent 认证（逗号分隔，支持多角色） ──
JINDAN_SECRETS=

# ── 轮询间隔（秒） ─────────────────────
# N 个 agent × HEARTBEAT = 完整轮询周期
AGENT_HEARTBEAT=10

# ── LLM 配置 ───────────────────────────
OPENAI_API_KEY=sk-你的API_KEY
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
