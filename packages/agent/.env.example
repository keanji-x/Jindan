# Agent 环境配置
# 复制此文件为 .env 并填入实际值

# ── API 服务器 ──────────────────────────
JINDAN_HOST=http://localhost:3001

# ── Agent 认证（二选一） ────────────────
# 方式 1: Entity Secret（推荐，从 Web UI 创建角色后获得）
JINDAN_SECRET=
# 方式 2: 直接指定 Entity ID（向下兼容）
# AGENT_ID=

# ── LLM 配置 ───────────────────────────
OPENAI_API_KEY=sk-你的API_KEY
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
